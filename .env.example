# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://thermal-guilt-api
AUTH0_AI_AGENT_CLIENT_ID=agent_m2m_client_id
AUTH0_AI_AGENT_CLIENT_SECRET=agent_m2m_secret

# Backboard
BACKBOARD_API_KEY=your_backboard_key
BACKBOARD_BASE_URL=https://app.backboard.io/api
BACKBOARD_ASSISTANT_ID=thermal_coach_id

# Google Gemini
GEMINI_API_KEY=your_gemini_key

# OpenAI / Featherless.ai
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.featherless.ai/v1

# Snowflake
SNOWFLAKE_ENABLED=false
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USERNAME=thermal_guilt_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=THERMAL_GUILT
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your_deployer_key
COOL_TOKEN_MINT=your_token_mint_address
PROGRAM_ID=your_anchor_program_id

# External APIs
OPENWEATHERMAP_API_KEY=your_key

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001

# API
PORT=3001
CORS_ORIGINS=http://localhost:3000,https://thermal-guilt-web.vercel.app
